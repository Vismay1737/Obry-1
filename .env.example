# OpenEnv CyberSOC — Environment Variables
# Copy this file to .env and fill in your values before running inference.
#
# Usage:
#   Windows: set API_BASE_URL=https://api-inference.huggingface.co/v1
#   Linux:   export API_BASE_URL=https://api-inference.huggingface.co/v1

# ── Required ──────────────────────────────────────────────────────────────────

# API endpoint for the OpenAI-compatible LLM.
# Examples:
#   Hugging Face:   https://api-inference.huggingface.co/v1
#   OpenAI:         https://api.openai.com/v1
#   Local (Ollama): http://localhost:11434/v1
API_BASE_URL=https://api-inference.huggingface.co/v1

# Model identifier to use for inference.
# Examples:
#   Hugging Face:   meta-llama/Llama-3.1-8B-Instruct
#   OpenAI:         gpt-4o-mini
#   Local:          llama3.1
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Your Hugging Face token (or OpenAI API key).
# Used as the api_key for the OpenAI client.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
